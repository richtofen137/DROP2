# =============================================
# AUTONOMOUS-DROP — Variables d'Environnement
# =============================================

# Server
PORT=3000
NODE_ENV=development
ADMIN_API_KEY=change_me_strong_secret_key
JWT_SECRET=change_me_jwt_secret

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# Apify
APIFY_API_TOKEN=your_apify_token_here

# CJDropshipping
CJDROP_API_KEY=your_cj_api_key_here
CJDROP_API_URL=https://developers.cjdropshipping.com/api2.0/v1

# AliExpress
ALIEXPRESS_APP_KEY=your_aliexpress_app_key
ALIEXPRESS_APP_SECRET=your_aliexpress_app_secret
ALIEXPRESS_ACCESS_TOKEN=your_aliexpress_token

# AutoDS
AUTODS_API_KEY=your_autods_api_key

# Zendrop
ZENDROP_API_KEY=your_zendrop_api_key

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Nodemailer SMTP (Gmail fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# IMAP (lecture emails clients)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASS=your_imap_password

# DataForSEO
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password

# ScraperAPI
SCRAPERAPI_KEY=your_scraperapi_key

# Google Search Console
GOOGLE_SERVICE_ACCOUNT_JSON=./config/google-service-account.json

# 17Track
TRACK17_API_KEY=your_17track_api_key

# SerpAPI
SERPAPI_KEY=your_serpapi_key

# SQLite
DB_PATH=./db/autonomous-drop.sqlite

# App domain (for sitemap)
APP_DOMAIN=https://yourdomain.com
